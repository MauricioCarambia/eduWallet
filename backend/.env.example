# Servidor
PORT=3001
NODE_ENV=development

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eduwallet
DB_USER=postgres
DB_PASSWORD=

# Autenticación
JWT_SECRET=cambiar_por_secreto_seguro_en_produccion

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# URLs (sin barra al final)
# En desarrollo: BACKEND_URL puede ser http://localhost:3001 con ngrok para recibir webhooks
BACKEND_URL=https://tu-backend.railway.app
PADRES_URL=https://tu-frontend-padres.vercel.app

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=notificaciones@tudominio.com

# Notificaciones push (PWA padres)
# Generar con: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tudominio.com
